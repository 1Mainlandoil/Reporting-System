VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Hosted Supabase (required for IT-created accounts to log in immediately):
# Dashboard → Authentication → Providers → Email → turn OFF "Confirm email".
# Password recovery links still need this redirect URL allowed under Authentication → URL configuration.
#
# Optional magic-link / recovery redirect (defaults to <origin>/auth/callback).
# VITE_AUTH_REDIRECT_URL=http://localhost:5173/auth/callback

# Local Supabase CLI: after `supabase init`, set [auth.email] enable_confirmations = false in config.toml to match.

# --- IT portal: password reset without email ---
# Deploy: supabase secrets set IT_PORTAL_SECRET="your-long-random-string"
#         supabase functions deploy set-auth-password
# IT portal .env: VITE_IT_PORTAL_SECRET=same string as IT_PORTAL_SECRET
# Function source: supabase/functions/set-auth-password/index.ts
